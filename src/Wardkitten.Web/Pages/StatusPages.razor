@page "/status-pages"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject WardkittenApiClient Api
@inject NavigationManager Nav

<PageTitle>Status pages · Wardkitten</PageTitle>

<h1 class="h3 mb-3">Status pages</h1>
<p class="text-muted">Comparte el estado de un conjunto de tareas mediante un enlace público. (Plan de pago.)</p>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Nueva página</h5>
        <input class="form-control mb-2" @bind="_title" placeholder="Título (p.ej. Estado de mis servicios)" />
        <label class="d-block mb-2"><input type="checkbox" @bind="_isPublic" /> Pública</label>
        <div class="mb-2">
            <label class="form-label">Incluir tareas:</label>
            @foreach (var w in _watches)
            {
                <label class="d-block"><input type="checkbox" checked="@_selected.Contains(w.Id)" @onchange="e => Toggle(w.Id, e)" /> @w.Name</label>
            }
        </div>
        @if (_error is not null)
        {
            <div class="alert alert-danger py-2">@_error</div>
        }
        <button class="btn btn-primary" @onclick="CreateAsync" disabled="@_busy">Crear</button>
    </div>
</div>

@foreach (var p in _pages)
{
    <div class="card mb-2">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <strong>@p.Title</strong> @(p.IsPublic ? "" : "(privada)")<br />
                <a href="@PublicUrl(p.Slug)" target="_blank"><code>@PublicUrl(p.Slug)</code></a>
            </div>
            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(p)">Borrar</button>
        </div>
    </div>
}

@code {
    private List<WatchDto> _watches = new();
    private List<StatusPageDto> _pages = new();
    private readonly HashSet<string> _selected = new();
    private string _title = string.Empty;
    private bool _isPublic = true;
    private string? _error;
    private bool _busy;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        var w = await Api.GetWatchesAsync();
        if (w.Ok && w.Value is not null) _watches = w.Value;
        var p = await Api.GetStatusPagesAsync();
        if (p.Ok && p.Value is not null) _pages = p.Value;
    }

    private void Toggle(string id, ChangeEventArgs e)
    {
        if (e.Value is true) _selected.Add(id); else _selected.Remove(id);
    }

    private async Task CreateAsync()
    {
        _busy = true; _error = null;
        var r = await Api.CreateStatusPageAsync(new StatusPageRequest(_title, _isPublic, _selected.ToList()));
        _busy = false;
        if (r.Ok) { _title = string.Empty; _selected.Clear(); await LoadAsync(); }
        else _error = r.Error;
    }

    private async Task DeleteAsync(StatusPageDto p) { await Api.DeleteStatusPageAsync(p.Id); await LoadAsync(); }

    private string PublicUrl(string slug) => $"{Nav.BaseUri}status/{slug}";
}
